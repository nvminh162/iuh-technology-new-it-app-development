<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Management</title>
</head>
<body>
    <h1>Danh sach ve</h1>

    <form action="/" method="get">
        <input name="q" placeholder="Tim theo eventName/holderName" value="<%= q || '' %>">
        <select name="status">
            <option value="">Tat ca status</option>
            <option value="Upcoming" <%= status === 'Upcoming' ? 'selected' : '' %>>Upcoming</option>
            <option value="Sold" <%= status === 'Sold' ? 'selected' : '' %>>Sold</option>
            <option value="Cancelled" <%= status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
        <button type="submit">Tim/Loc</button>
        <a href="/">Reset</a>
    </form>

    <br>
    <a href="/upsert">Them ve</a>
    <table border="1">
        <tr>
            <th>ticketId</th>
            <th>eventName</th>
            <th>holderName</th>
            <th>category</th>
            <th>quantity</th>
            <th>pricePerTicket</th>
            <th>eventDate</th>
            <th>status</th>
            <th>image</th>
            <th>createdAt</th>
            <th>totalAmount</th>
            <th>finalAmount</th>
            <th>discountLabel</th>
            <th>ACTION</th>
        </tr>
        <% if (!tickets || tickets.length === 0) { %>
            <tr>
                <td colspan="14">Khong co ve</td>
            </tr>
        <% } else { %>
            <% tickets.forEach(ticket => { %>
                <tr>
                    <td><%= ticket.ticketId %></td>
                    <td><%= ticket.eventName %></td>
                    <td><%= ticket.holderName %></td>
                    <td><%= ticket.category %></td>
                    <td><%= ticket.quantity %></td>
                    <td><%= ticket.pricePerTicket %></td>
                    <td><%= ticket.eventDate %></td>
                    <td><%= ticket.status %></td>
                    <td>
                        <% if (ticket.imageUrl) { %>
                            <img src="<%= ticket.imageUrl %>" alt="ticket image" width="80">
                        <% } else { %>
                            N/A
                        <% } %>
                    </td>
                    <td><%= ticket.createdAt %></td>
                    <td><%= ticket.totalAmount || 0 %></td>
                    <td><%= ticket.finalAmount || 0 %></td>
                    <td><%= ticket.discountLabel || 'Khong giam gia' %></td>
                    <td>
                        <a href="/ticket/<%= ticket.ticketId %>">Xem</a>
                        <a href="/upsert/<%= ticket.ticketId %>">Sua</a>
                        <form action="/delete/<%= ticket.ticketId %>" method="post" style="display:inline;">
                            <button type="submit">Xoa</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        <% } %>
    </table>
</body>
</html>