<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Detail</title>
</head>
<body>
    <h1>Xem chi tiết</h1>
    <% if (ticket == null) { %>
        <p>Vé không tồn tại</p>
    <% } else { %>
        <p>Ticket ID: <%= ticket.ticketId %></p>
        <p>Event Name: <%= ticket.eventName %></p>
        <p>Holder Name: <%= ticket.holderName %></p>
        <p>Category: <%= ticket.category %></p>
        <p>Quantity: <%= ticket.quantity %></p>
        <p>Price per ticket: <%= ticket.pricePerTicket %></p>
        <p>Event date: <%= ticket.eventDate %></p>
        <p>Status: <%= ticket.status %></p>
        <p>Created At: <%= ticket.createdAt %></p>
        <% if (ticket.imageUrl) { %>
            <p><img src="<%= ticket.imageUrl %>" alt="ticket image" width="220"></p>
        <% } %>
    <% } %>
</body>
</html>