<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= ticket ? 'Edit ticket' : 'Add ticket' %>
    </title>
</head>

<body>
    <h1>
        <%= ticket ? 'Sửa vé' : 'Thêm vé' %>
    </h1>

    <% if (error) { %>
        <p style="color:red;">
            <%= error %>
        </p>
        <% } %>

            <form action="<%= ticket ? '/upsert/' + ticket.ticketId : '/upsert' %>" method="post"
                enctype="multipart/form-data">
                <input name="eventName" placeholder="eventName" value="<%= ticket?.eventName || '' %>" required>
                <br>
                <input name="holderName" placeholder="holderName" value="<%= ticket?.holderName || '' %>" required>
                <br>
                <select name="category" required>
                    <option value="Standard" <%=ticket?.category==='Standard' ? 'selected' : '' %>>Standard</option>
                    <option value="VIP" <%=ticket?.category==='VIP' ? 'selected' : '' %>>VIP</option>
                    <option value="VVIP" <%=ticket?.category==='VVIP' ? 'selected' : '' %>>VVIP</option>
                </select>
                <br>
                <input name="quantity" type="number" min="1" value="<%= ticket?.quantity || '' %>" required>
                <br>
                <input name="pricePerTicket" type="number" min="1" value="<%= ticket?.pricePerTicket || '' %>" required>
                <br>
                <input name="eventDate" type="date"
                    value="<%= ticket?.eventDate ? String(ticket.eventDate).slice(0, 10) : '' %>" required>
                <br>
                <select name="status" required>
                    <option value="Upcoming" <%=ticket?.status==='Upcoming' ? 'selected' : '' %>>Upcoming</option>
                    <option value="Sold" <%=ticket?.status==='Sold' ? 'selected' : '' %>>Sold</option>
                    <option value="Cancelled" <%=ticket?.status==='Cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <br>
                <input name="image" type="file" accept="image/*" <%=ticket ? '' : 'required' %>>
                <% if (ticket?.imageUrl) { %>
                    <img src="<%= ticket.imageUrl %>" alt="ticket image" width="120">
                    <% } %>
                        <br>
                        <button type="submit">
                            <%= ticket ? 'Cap nhat' : 'Them moi' %>
                        </button>
                        <a href="/">Quay lai</a>
            </form>
</body>

</html>