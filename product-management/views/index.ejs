<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Danh sách</h1>
    <a href="/form">Thêm</a>
    <table border="1" width="80%" style="text-align: center;">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Image</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Amount</th>
            <th>ACTION</th>
        </tr>
        <% if (!items || items.length === 0) { %>
            <tr>
                <td colspan="8">Không có sản phẩm nào</td>
            </tr>
            <% } else { %>
                <% items.forEach(item => { %>
                    <% const status = statusLabel(item?.quantity || 0); %>
                    <% const amount = computeAmount(item?.price || 0, item?.quantity || 0); %>
                    <tr>
                        <td><%= item.id %></td>
                        <td><%= item.name %></td>
                        <td><%= item.price %></td>
                        <td>
                            <% if (item.image) { %>
                                <img src=<%= item.image %> alt="" width="100">
                            <% } else { %>
                                Chưa upload ảnh
                            <% } %>
                        </td>
                        <td><%= item.quantity %></td>
                        <td><%= status %></td>
                        <td><%= amount %></td>
                        <td>
                            <a href="/form/<%= item.id %>">Sửa</a>
                            <form action="/items/delete/<%= item.id %>" method="POST">
                                <button type="submit">Xoá</button>
                            </form>
                        </td>
                    </tr>
            <% }) %>
        <% } %>  
    </table>
</body>
</html>